## Positions in [m] where +z is roated by sbs.theta.
# the "position" variables below are only relevant if there are tracking detectors in SBS, the positions are given relative to the origin of the GEM coordinate system.
# the first SBS experiment with GEMs is GEN.
# note 12.35 m is the estimated distance from the first SBS GEM layer to the surface of HCAL during GEN, but see kinematics-dependent adjustments below!
sbs.hcal.position = 0 0 12.35

## HCal is composed of 4 sub-assemblies each of 6x12 (row,col) modules
## Test settings for one sub-assembly
sbs.hcal.size  =  1.8567  0.9461  1.0000

## HCal is a matrix of with nrows and ncols
sbs.hcal.nrows = 24
sbs.hcal.ncols = 12

## Default tdc timewalk calibration parameters
sbs.hcal.tdc.tw = 0.78 0.50

## Position of first module
sbs.hcal.xyz = -2.190625 -0.85217 0.0 #Overridden by detailed ypos and xpos below
## Space between modules
sbs.hcal.dxdydz = 0.15875 0.15494 0.0 #Overridden by detailed ypos and xpos below
