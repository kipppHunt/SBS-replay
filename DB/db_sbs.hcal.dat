  17    8     0    31 2 # 32 channels
  17    8     32   32 2 # 1 channel. Sum module trigger copy (logical). sbs.hcal.Ref.tdc[0]
  17    8     34   34 2 # 1 channel. Copy of DVCS pulser EDTM signal (logical). sbs.hcal.Ref.tdc[1]
  17    8     35   35 2 # 1 channel. Copy of BB trigger (logical). TDC reference channel. sbs.hcal.Ref.tdc[2]
  17    8     36   36 2 # 1 channel. RF (logical). sbs.hcal.Ref.tdc[3]

# what happens when a ref. channel (according to the chanmap) is assigned a ref. index according to the detmap?
# Apparently nothing. If a channel is defined as ref in the chanmap by specifying index -1000,
# Then the ref index has no effect on the decoding.
# define crate, slot, channel for RF time and trigger time (copy of BB trigger recorded in F1, NOT the F1 low-res trigger time itself):
sbs.hcal.crate_rftime = 17
sbs.hcal.slot_rftime = 8
sbs.hcal.chan_rftime = 36

sbs.hcal.crate_trigtime = 17
sbs.hcal.slot_trigtime = 8
sbs.hcal.chan_trigtime = 35

sbs.hcal.usetrigphasecorr = 0
sbs.hcal.trigphaseoffset = 2
sbs.hcal.trigphasemultiple = 6

sbs.hcal.nmax_cluster = 25

sbs.hcal.ledmap = 16 30

## Channel map from channel to logical channel
sbs.hcal.start_chanmap=1
sbs.hcal.chanmap = 
