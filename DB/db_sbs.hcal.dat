sbs.hcal.adc.timeoffset = 0.0

# let's go ahead and put in some sensible offline clustering thresholds:
# lowering these offline thresholds as they seem to be cutting out too many good hits.
sbs.hcal.emin = 0.02 #
sbs.hcal.emin_clSeed = 0.1 # 5 MeV, cluster seed threshold (offline)
sbs.hcal.emin_clTotal = 0.5 # 10 MeV, cluster total threshold (offline) 


sbs.hcal.tmax = 20.0 # will shrink when we do FADC time alignment (reduced from 100.0 during gep 6/2)

# HCAL position for back tracker search region constraint:
# AJRP 2025-04-07: we offset HCAL position vertically to compensate for vertical offset of GEM coordinate system. The "position" variable specifies the HCAL origin in
# GEM coordinates (we might need to modify the code too, oh wait, nope, the code already does this correctly). 
# since HCAL is 10 m from the target and our initial guess for the origin of the GEM coordinate system is 3.685 m from target, HCAL z position should be 
# 6.315 m (initial guess, will need adjustment)

# adjusting HCAL position relative to aligned GEM coordinate system 
# (AJRP 4/20/2025):
# this one works for Kin. 1:

sbs.hcal.position = 0.1535 0.0 6.3813



