# max separation between PMTs for grouping into clusters:
bb.grinch_tdc.maxsep = 0.072 # this is twice the separation between neighboring PMTs in the matrix, to account for clusters with "holes"

bb.grinch_tdc.nmirror = 4

# commenting these out for testing new cuts based on Maria's parametrizations:

#bb.grinch_tdc.trackmatch_pslope = 0.1715
#bb.grinch_tdc.trackmatch_xslope = 0.74 0.7353 0.7515 0.7456 
#bb.grinch_tdc.trackmatch_x0 = -0.2 -0.0765 -0.0827 0.1127 
#bb.grinch_tdc.trackmatch_xsigma = 0.015 0.009 0.01 0.01 
#bb.grinch_tdc.trackmatch_yslope = 0.42 0.48 0.173 0.56 
#bb.grinch_tdc.trackmatch_y0 = -0.017 0.018 0.014 0.046 
#bb.grinch_tdc.trackmatch_ysigma = 0.022 0.015 0.022 0.023 
#bb.grinch_tdc.trackmatch_xmin = -0.8 -0.65 -0.1 0.45
#bb.grinch_tdc.trackmatch_xmax = -0.5 0.1 0.55 0.8 

# wide track-matching cut until we develop a way to deal with the mirror boundaries in the x track x GRINCH correlation 
# 4.5-sigma cut seems sufficiently loose for now:
bb.grinch_tdc.trackmatch_nsigma_cut = 5.0

# for kinematics not yet calibrated, start with wider timing cuts
bb.grinch_tdc.hit_mintime = -50
bb.grinch_tdc.hit_maxtime = 50

# start with more open definitions of these cuts for earlier kinematics that aren't yet aligned:
bb.grinch_tdc.maxtdiff_clust = 25.0 # time difference limit for adding GRINCH hits to clusters (ns)
bb.grinch_tdc.maxtdiff_ref = 100.0 # time difference limit for GRINCH hits relative to shower for consideration in good clusters (ns)
bb.grinch_tdc.usereftimediffcut = 0 # flag to enable/disable the use of shower ADC time as "reference time" for GRINCH

bb.grinch_tdc.trackmatch_dtsigma = 1.3 # ns (sigma of mean time for "good" GRINCH electron clusters relative to shower)
bb.grinch_tdc.trackmatch_dtoffset = 0.0 # ns

# the following lines will basically disable the GRINCH for the earlier GMN kinematics (SBS-1, SBS-4), as the GRINCH data for these settings aren't (generally speaking) useful:
bb.grinch_tdc.hit_mintime = 0
bb.grinch_tdc.hit_maxtime = 0

# It appears we have "good" GRINCH data starting with SBS-7:

---------[ 2021-11-13 9:00:00 ] # start of SBS-7

# the cluster mean time resolution starts at about 2.2 ns (gets better once we start flowing heavy gas):

bb.grinch_tdc.hit_mintime = -30.0
bb.grinch_tdc.hit_maxtime = 30.0

bb.grinch_tdc.maxtdiff_clust = 20.0
bb.grinch_tdc.maxtdiff_ref = 20.0
bb.grinch_tdc.usereftimediffcut = 1

bb.grinch_tdc.trackmatch_dtsigma = 2.5

# based on raw TDC distributions, use -69.1 ns wrt SBS-9 as starting point:
bb.grinch_tdc.tdc.offset = 
